#!/bin/bash

# Avoid interactive prompts during package installation
export DEBIAN_FRONTEND=noninteractive

# Install dependencies: QEMU and the Docker client
sudo apt-get update && sudo apt-get install -y --no-install-recommends \
    qemu-system-x86 \
    qemu-utils \
    docker.io \
    libguestfs-tools \
    ca-certificates \
    linux-image-generic \
    curl

sudo mkdir -p /opt
sudo curl -L "https://dl-cdn.alpinelinux.org/alpine/v3.20/releases/cloud/nocloud_alpine-3.20.0-x86_64-bios-cloudinit-r0.qcow2" -o /opt/alpine-docker.qcow2

sudo qemu-img resize /opt/alpine-docker.qcow2 10G

sudo guestfish -a /opt/alpine-docker.qcow2 --rw <<EOF
run
e2fsck-f /dev/sda
resize2fs /dev/sda
exit
EOF

sudo virt-customize -a /opt/alpine-docker.qcow2 \
   --run-command "apk del cloud-init" \
   --install openssh,docker \
   --run-command "rc-update add sshd default" \
   --run-command "rc-update add docker default" \
   --run-command "echo 'PermitRootLogin yes' >> /etc/ssh/sshd_config" \
   --run-command "echo 'DOCKER_OPTS=\"-H tcp://0.0.0.0:2375 -H unix:///var/run/docker.sock\"' >> /etc/conf.d/docker" \
   --root-password password:alpine
