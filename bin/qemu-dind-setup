#!/bin/bash

# Avoid interactive prompts during package installation
export DEBIAN_FRONTEND=noninteractive

# Use sudo if command exists and we are not root
SUDO=""
if [ "$(id -u)" -ne 0 ] && command -v sudo >/dev/null 2>&1; then
  SUDO="sudo"
fi

# Install minimal runtime dependencies: QEMU, Docker client, curl
echo "Installing minimal runtime dependencies..."
$SUDO apt-get update && $SUDO apt-get install -y --no-install-recommends \
    qemu-system-x86 \
    docker.io \
    ca-certificates \
    procps \
    sshpass \
    curl

# Download pre-built image from GitHub Release assets
REPO="${REPO:-jonasGuest/qemu-dind}"

IMAGE_URL="https://github.com/${REPO}/releases/latest/download/alpine-docker.qcow2"

echo "Downloading pre-built QEMU VM image from ${IMAGE_URL}..."
$SUDO mkdir -p /opt
$SUDO curl -L "${IMAGE_URL}" -o /opt/alpine-docker.qcow2

if [ $? -ne 0 ] || [ ! -f /opt/alpine-docker.qcow2 ]; then
  echo "Error: Failed to download the pre-built image from GitHub assets." >&2
  exit 1
fi

echo "Setup completed successfully! VM image downloaded to /opt/alpine-docker.qcow2."
