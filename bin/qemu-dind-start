#!/bin/bash

# Define VM image path
VM_IMAGE="/opt/alpine-docker.qcow2"
if [ ! -f "$VM_IMAGE" ]; then
  echo "Error: VM image $VM_IMAGE does not exist." >&2
  exit 1
fi

# Ensure log directory exists
sudo mkdir -p /var/log

# Start QEMU in background using setsid and redirect output under sudo
sudo sh -c 'setsid qemu-system-x86_64 \
  -m 2G \
  -smp 2 \
  -nic user,model=virtio-net-pci,hostfwd=tcp::2222-:22,hostfwd=tcp::2375-:2375,hostfwd=tcp::8080-:80 \
  -drive file="'"$VM_IMAGE"'",media=disk,if=virtio \
  -nographic > /var/log/qemu-dind.log 2>&1 &'

# Wait a moment for QEMU to start up and then locate its PID
sleep 1
QEMU_PID=$(pgrep -f "qemu-system-x86_64.*alpine-docker.qcow2")

if [ -n "$QEMU_PID" ]; then
  echo "$QEMU_PID" | sudo tee /var/run/qemu-dind.pid > /dev/null
  echo "QEMU VM started in background with PID $QEMU_PID. Logs redirected to /var/log/qemu-dind.log"
else
  echo "Failed to start QEMU VM. Check /var/log/qemu-dind.log"
  exit 1
fi
