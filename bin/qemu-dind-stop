#!/bin/bash

# Use sudo if command exists and we are not root
SUDO=""
if [ "$(id -u)" -ne 0 ] && command -v sudo >/dev/null 2>&1; then
  SUDO="sudo"
fi

# Stop SSH tunnel using ControlMaster socket if it exists
SOCKET_FILE="/tmp/qemu-dind-ssh.sock-$(id -u)"
if [ -S "$SOCKET_FILE" ]; then
  echo "Stopping SSH tunnel..."
  ssh -S "$SOCKET_FILE" -O exit -p 2222 root@127.0.0.1 2>/dev/null
  rm -f "$SOCKET_FILE"
fi

# Fallback: kill any remaining ssh tunnels matching the pattern
for cmdfile in /proc/[0-9]*/cmdline; do
  if [ -f "$cmdfile" ]; then
    cmd=$(tr '\0' ' ' < "$cmdfile" 2>/dev/null)
    if [[ "$cmd" == *"ssh "* && "$cmd" == *"-p 2222"* && "$cmd" == *"root@127.0.0.1"* ]]; then
      pid=$(basename "$(dirname "$cmdfile")")
      if [ -n "$pid" ] && [ "$pid" -ne "$$" ]; then
        echo "Killing leftover SSH tunnel process (PID: $pid)..."
        kill "$pid" 2>/dev/null
      fi
    fi
  fi
done

PID_FILE="/var/run/qemu-dind.pid"


if [ ! -f "$PID_FILE" ]; then
  # Fallback: check if qemu-system-x86_64 is running
  QEMU_PID=$(pgrep -f "qemu-system-x86_64.*alpine-docker.qcow2")
  if [ -z "$QEMU_PID" ]; then
    echo "No running QEMU VM found."
    exit 0
  fi
else
  QEMU_PID=$(cat "$PID_FILE")
fi

echo "Stopping QEMU VM (PID: $QEMU_PID)..."
$SUDO kill -15 "$QEMU_PID" 2>/dev/null

# Wait up to 10 seconds for graceful shutdown
for i in {1..10}; do
  if ! $SUDO kill -0 "$QEMU_PID" 2>/dev/null; then
    echo "QEMU VM stopped gracefully."
    $SUDO rm -f "$PID_FILE"
    exit 0
  fi
  sleep 1
done

echo "VM did not exit gracefully, killing forcefully..."
$SUDO kill -9 "$QEMU_PID" 2>/dev/null
$SUDO rm -f "$PID_FILE"
